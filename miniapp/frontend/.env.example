# Пусто — фронт идёт через Vite-proxy на /api → localhost:8000
VITE_API_BASE=

# initData из Telegram WebApp для dev (иначе API вернёт 401).
# Как получить:
#   1. Открой своего бота в Telegram, запусти Mini App.
#   2. DevTools (на desktop Telegram: правый клик → Inspect).
#   3. В консоли: window.Telegram.WebApp.initData
#   4. Скопируй строку сюда. Живёт 24 часа — обновляй по мере надобности.
VITE_DEV_INIT_DATA=
