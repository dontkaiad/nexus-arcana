# ============================================================
#  nexus-arcana — шаблон .env. Скопируй в .env и заполни.
#  .env НЕ коммитить. Этот файл (.env.example) — без секретов.
# ============================================================

# ── ОБЯЗАТЕЛЬНЫЕ ──────────────────────────────────────────
# Anthropic API (Claude) — отдельный API-ключ, НЕ подписка Claude.ai
ANTHROPIC_API_KEY=
# Токен бота Nexus (@nexus_kailark_bot) от @BotFather
NEXUS_BOT_TOKEN=
# Твой Telegram ID (несколько — через запятую)
ALLOWED_TELEGRAM_IDS=
# Postgres. На сервере внутри compose host = db (имя сервиса).
# Локально было: ...@localhost:5432/...  Пароль должен совпадать с POSTGRES_PASSWORD ниже.
DATABASE_URL=postgresql+psycopg2://kai:CHANGE_ME@db:5432/nexus_arcana
# Пароль Postgres в контейнере (совпадает с паролем в DATABASE_URL)
POSTGRES_PASSWORD=

# ── ARCANA (нужно, чтобы поднялся второй бот) ─────────────
ARCANA_BOT_TOKEN=

# ── ФИЧИ (опционально, но у тебя в коде используются) ─────
# Голос (Whisper через OpenAI API). Без него voice не работает.
OPENAI_API_KEY=
# Cloudinary (фото клиентов/раскладов). Одной строкой URL ЛИБО тремя полями.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── RAG (Voyage AI embeddings + pgvector) — опционально ──
# Без VOYAGE_API_KEY эмбеддинги отключены (graceful no-op, боты работают).
# Векторный стор — pgvector в том же Postgres (DATABASE_URL выше), своих env нет.
VOYAGE_API_KEY=

# ── Mini App (если поднимаешь фронт) ─────────────────────
MINIAPP_CORS_ORIGINS=
MINIAPP_INIT_DATA_TTL=
# Базовый URL Mini App — боты ставят WebApp-кнопку меню на старте.
# Дефолт: https://core.heylark.dev (менять только если домен другой).
MINIAPP_BASE_URL=

# ── Лог-группа: ошибки Nexus/Arcana → общая TG-группа ────
# Опционально. Если TG_LOG_BOT_TOKEN или TG_LOG_CHAT_ID пусты — отправка
# выключена, боты работают как раньше.
# Токен ОБЩЕГО лог-бота (НЕ Nexus/Arcana) от @BotFather. Лог-бот должен
# быть участником группы.
TG_LOG_BOT_TOKEN=
# id группы логов (отрицательный, напр. -1001234567890).
TG_LOG_CHAT_ID=
# message_thread_id топиков форума (если в группе включены Топики) —
# Nexus и Arcana в свои топики. Пусто → шлём без топика.
TG_LOG_THREAD_NEXUS=
TG_LOG_THREAD_ARCANA=

# ── NOTION больше НЕ нужно — миграция на Postgres завершена ─
